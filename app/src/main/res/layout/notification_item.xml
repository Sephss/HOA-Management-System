<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/document_request_bg"
    android:orientation="vertical"
    android:padding="16dp">
    <View
        android:id="@+id/unreadDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/blue_circle_bg"
        android:visibility="gone"/>
    <TextView
        android:id="@+id/notifTitleTV"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Document Request Updated"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/notifMessageTV"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Your Certificate of Residency request has been approved."
        android:textColor="@color/darkergrey"
        android:textSize="14sp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/notifDateTV"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="July 12, 2026"
            android:textColor="@color/grey"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/notifTimeTV"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:30 AM"
            android:textColor="@color/grey"
            android:textSize="12sp"/>

    </LinearLayout>

</LinearLayout>