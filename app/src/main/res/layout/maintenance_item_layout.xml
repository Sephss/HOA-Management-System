<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:layout_marginHorizontal="12dp"
android:layout_marginVertical="6dp"
android:background="@drawable/document_request_bg"
android:orientation="vertical"
android:padding="16dp">

<!-- Header -->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tvMaintenanceType"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Streetlight Repair"
        android:textColor="@color/black"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/pending_document_request"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:text="Pending"
        android:textColor="@color/darkyellow"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>

<!-- Description -->
<TextView
    android:id="@+id/tvDescription"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:ellipsize="end"
    android:maxLines="2"
    android:text="Streetlight near the main entrance is not functioning."
    android:textColor="@color/darkergrey"
    android:textSize="14sp" />

<!-- Footer -->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tvLocation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Block 5"
        android:textColor="@color/darkergrey"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jul 10, 2026"
        android:textColor="@color/darkergrey"
        android:textSize="12sp" />

</LinearLayout>

    <TextView
        android:id="@+id/viewDetailsTV"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="View Details"
        android:textSize="12sp"
        android:textColor="@color/white"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:background="@drawable/view_details_bg" />

</LinearLayout>